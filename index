<body lang="en-US" link="#000080" vlink="#800000" dir="ltr"><pre class="western">&lt;!DOCTYPE html&gt;
&lt;html lang=&quot;ja&quot;&gt;
&lt;head&gt;
    &lt;meta charset=&quot;UTF-8&quot;&gt;
    &lt;meta name=&quot;viewport&quot; content=&quot;width=device-width, initial-scale=1.0&quot;&gt;
    &lt;title&gt;<font face="Noto Sans Mono CJK SC, monospace"><span lang="zh-CN">温度計 </span></font>OCR <font face="Noto Sans Mono CJK SC, monospace"><span lang="zh-CN">アラートシステム</span></font>&lt;/title&gt;
    &lt;script src=&quot;https://cdn.jsdelivr.net/npm/tesseract.js@4/dist/tesseract.min.js&quot;&gt;&lt;/script&gt;
    &lt;style&gt;
        :root { --primary-color: #007bff; --danger-color: #dc3545; --success-color: #28a745; }
        body { font-family: -apple-system, sans-serif; background: #1a1a1a; color: white; margin: 0; display: flex; flex-direction: column; align-items: center; }
        
        #app-container { width: 100%; max-width: 480px; padding: 20px; box-sizing: border-box; }
        
        /* <font face="Noto Sans Mono CJK SC, monospace"><span lang="zh-CN">映像表示エリア </span></font>*/
        .video-wrapper { position: relative; width: 100%; border-radius: 15px; overflow: hidden; border: 2px solid #444; background: black; }
        video { width: 100%; display: block; }
        
        /* <font face="Noto Sans Mono CJK SC, monospace"><span lang="zh-CN">設定エリア </span></font>*/
        .config-panel { background: #333; margin-top: 15px; padding: 15px; border-radius: 12px; display: flex; justify-content: space-around; align-items: center; }
        input[type=&quot;number&quot;] { width: 80px; font-size: 1.2rem; padding: 5px; border-radius: 5px; border: none; text-align: center; }
        
        /* <font face="Noto Sans Mono CJK SC, monospace"><span lang="zh-CN">結果表示エリア </span></font>*/
        .result-panel { margin-top: 15px; padding: 20px; border-radius: 12px; background: #222; text-align: center; transition: 0.3s; }
        #current-val { font-size: 3.5rem; font-weight: bold; color: var(--primary-color); font-family: 'Courier New', monospace; }
        
        /* <font face="Noto Sans Mono CJK SC, monospace"><span lang="zh-CN">アラート状態のスタイル </span></font>*/
        .alert-active { background-color: var(--danger-color) !important; animation: blink 0.6s infinite; }
        @keyframes blink { 0% { opacity: 1; } 50% { opacity: 0.7; } 100% { opacity: 1; } }

        button { width: 100%; padding: 15px; font-size: 1.1rem; font-weight: bold; border: none; border-radius: 12px; margin-top: 15px; cursor: pointer; transition: 0.3s; }
        .btn-start { background: var(--success-color); color: white; }
        .btn-stop { background: #666; color: white; }
    &lt;/style&gt;
&lt;/head&gt;
&lt;body&gt;

&lt;div id=&quot;app-container&quot;&gt;
    &lt;h2 style=&quot;text-align: center; margin: 10px 0;&quot;&gt;<font face="Noto Sans Mono CJK SC, monospace"><span lang="zh-CN">温度モニター </span></font>AI&lt;/h2&gt;
    
    &lt;div class=&quot;video-wrapper&quot;&gt;
        &lt;video id=&quot;video&quot; autoplay playsinline&gt;&lt;/video&gt;
    &lt;/div&gt;

    &lt;div class=&quot;config-panel&quot;&gt;
        &lt;div&gt;
            &lt;span&gt;<font face="Noto Sans Mono CJK SC, monospace"><span lang="zh-CN">通知温度</span></font>: &lt;/span&gt;
            &lt;input type=&quot;number&quot; id=&quot;threshold&quot; value=&quot;30.0&quot; step=&quot;0.1&quot;&gt; ℃
        &lt;/div&gt;
    &lt;/div&gt;

    &lt;div class=&quot;result-panel&quot; id=&quot;display-area&quot;&gt;
        &lt;div style=&quot;font-size: 0.9rem; opacity: 0.8;&quot;&gt;<font face="Noto Sans Mono CJK SC, monospace"><span lang="zh-CN">現在の認識数値</span></font>&lt;/div&gt;
        &lt;div id=&quot;current-val&quot;&gt;--.-&lt;/div&gt;
        &lt;div id=&quot;status-text&quot; style=&quot;font-size: 0.8rem; margin-top: 5px;&quot;&gt;<font face="Noto Sans Mono CJK SC, monospace"><span lang="zh-CN">停止中</span></font>&lt;/div&gt;
    &lt;/div&gt;

    &lt;button id=&quot;main-btn&quot; class=&quot;btn-start&quot;&gt;<font face="Noto Sans Mono CJK SC, monospace"><span lang="zh-CN">監視スタート</span></font>&lt;/button&gt;
&lt;/div&gt;

&lt;script&gt;
    const video = document.getElementById('video');
    const mainBtn = document.getElementById('main-btn');
    const currentValDisplay = document.getElementById('current-val');
    const displayArea = document.getElementById('display-area');
    const thresholdInput = document.getElementById('threshold');
    const statusText = document.getElementById('status-text');

    let isMonitoring = false;
    let scanInterval = null;
    let isSpeaking = false;

    // --- <font face="Noto Sans Mono CJK SC, monospace"><span lang="zh-CN">音声通知関数 </span></font>---
    function speakAlert(temp) {
        if (isSpeaking) return;
        isSpeaking = true;
        
        const msg = new SpeechSynthesisUtterance();
        msg.text = `<font face="Noto Sans Mono CJK SC, monospace"><span lang="zh-CN">警告。温度が</span></font>${temp}<font face="Noto Sans Mono CJK SC, monospace"><span lang="zh-CN">度を超えました。</span></font>`;
        msg.lang = 'ja-JP';
        msg.onend = () =&gt; {
            // <font face="Noto Sans Mono CJK SC, monospace"><span lang="zh-CN">連続発話を防ぐため、少し間隔をあける</span></font>
            setTimeout(() =&gt; { isSpeaking = false; }, 3000);
        };
        window.speechSynthesis.speak(msg);
    }

    // --- <font face="Noto Sans Mono CJK SC, monospace"><span lang="zh-CN">メイン処理 </span></font>---
    mainBtn.onclick = async () =&gt; {
        if (!isMonitoring) {
            try {
                const stream = await navigator.mediaDevices.getUserMedia({ 
                    video: { facingMode: &quot;environment&quot;, width: { ideal: 1280 }, height: { ideal: 720 } },
                    audio: false 
                });
                video.srcObject = stream;
                
                isMonitoring = true;
                mainBtn.innerText = &quot;<font face="Noto Sans Mono CJK SC, monospace"><span lang="zh-CN">監視を停止する</span></font>&quot;;
                mainBtn.className = &quot;btn-stop&quot;;
                statusText.innerText = &quot;<font face="Noto Sans Mono CJK SC, monospace"><span lang="zh-CN">解析中</span></font>...&quot;;

                // 3<font face="Noto Sans Mono CJK SC, monospace"><span lang="zh-CN">秒に</span></font>1<font face="Noto Sans Mono CJK SC, monospace"><span lang="zh-CN">回スキャン</span></font>
                scanInterval = setInterval(doOCR, 3000);
                
                // <font face="Noto Sans Mono CJK SC, monospace"><span lang="zh-CN">初回起動時にダミーの音声を流す（ブラウザのロック解除用）</span></font>
                const startupMsg = new SpeechSynthesisUtterance(&quot;&quot;);
                window.speechSynthesis.speak(startupMsg);

            } catch (err) {
                alert(&quot;<font face="Noto Sans Mono CJK SC, monospace"><span lang="zh-CN">カメラを起動できませんでした。</span></font>HTTPS<font face="Noto Sans Mono CJK SC, monospace"><span lang="zh-CN">接続を確認してください。</span></font>&quot;);
            }
        } else {
            // <font face="Noto Sans Mono CJK SC, monospace"><span lang="zh-CN">停止処理</span></font>
            clearInterval(scanInterval);
            const stream = video.srcObject;
            stream.getTracks().forEach(track =&gt; track.stop());
            video.srcObject = null;
            
            isMonitoring = false;
            mainBtn.innerText = &quot;<font face="Noto Sans Mono CJK SC, monospace"><span lang="zh-CN">監視スタート</span></font>&quot;;
            mainBtn.className = &quot;btn-start&quot;;
            statusText.innerText = &quot;<font face="Noto Sans Mono CJK SC, monospace"><span lang="zh-CN">停止中</span></font>&quot;;
            displayArea.classList.remove('alert-active');
        }
    };

    // --- OCR<font face="Noto Sans Mono CJK SC, monospace"><span lang="zh-CN">実行 </span></font>---
    async function doOCR() {
        if (!isMonitoring) return;

        // Tesseract<font face="Noto Sans Mono CJK SC, monospace"><span lang="zh-CN">の設定</span></font>: <font face="Noto Sans Mono CJK SC, monospace"><span lang="zh-CN">数字とドットのみを許可</span></font>
        const result = await Tesseract.recognize(video, 'eng', {
            tessedit_char_whitelist: '0123456789.',
            logger: m =&gt; { if(m.status === 'recognizing') statusText.innerText = `<font face="Noto Sans Mono CJK SC, monospace"><span lang="zh-CN">解析中</span></font>...(${Math.round(m.progress * 100)}%)`; }
        });

        const rawText = result.data.text.replace(/[^0-9.]/g, '');
        const num = parseFloat(rawText);
        
        if (!isNaN(num)) {
            currentValDisplay.innerText = num.toFixed(1);
            const limit = parseFloat(thresholdInput.value);

            if (num &gt;= limit) {
                displayArea.classList.add('alert-active');
                speakAlert(num.toFixed(1));
                if (navigator.vibrate) navigator.vibrate([500, 200, 500]);
            } else {
                displayArea.classList.remove('alert-active');
            }
        } else {
            statusText.innerText = &quot;<font face="Noto Sans Mono CJK SC, monospace"><span lang="zh-CN">数値を読み取れません</span></font>...&quot;;
        }
    }
&lt;/script&gt;

&lt;/body&gt;
